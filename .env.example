GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
HOST=0.0.0.0
PORT=4173
NODE_ENV=development

# Server-side only. Never expose the service-role key in browser code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Use a long random value so signed browser sessions remain valid after restarts.
SESSION_SECRET=

# Add this URL to Supabase Authentication > URL Configuration > Redirect URLs.
AUTH_REDIRECT_URL=http://localhost:4173/

# Optional for `npm run migrate`. Use the Supabase transaction-pooler or direct
# PostgreSQL connection string and keep it server-side.
DATABASE_URL=
DATABASE_SSL=true

# Optional. POST JSON error/fatal logs to an external alerting endpoint.
ERROR_WEBHOOK_URL=

# Optional. Enables shared rate limiting across multiple app instances.
# Compatible with Redis REST providers such as Upstash.
REDIS_REST_URL=
REDIS_REST_TOKEN=
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
